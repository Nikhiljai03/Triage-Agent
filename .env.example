# =============================================================================
# Triage Agent — example environment. Copy to .env and fill in real values:
#     cp .env.example .env
# Nothing reads os.environ directly; shared/config.py is the single source.
# =============================================================================

# ----- Safety (read these first) ---------------------------------------------
# !! GitHub writes require a DELIBERATE DOUBLE OPT-IN. A write happens only when
# !! BOTH gates below are flipped: DRY_RUN=false AND ENABLE_LIVE_WRITES=true.
# !! Keep these at their safe defaults unless you are intentionally going live on
# !! a repo YOU CONTROL. Even when live, only non-destructive actions are allowed
# !! (add label, post comment, open DRAFT pr) — never close/merge/delete.
DRY_RUN=true                 # GATE 1: true = never perform live GitHub writes (default)
ENABLE_LIVE_WRITES=false     # GATE 2: explicit master switch; must be true to ever write
LIVE_WRITE_REPO=             # if set, the ONLY repo writes may target (overrides TARGET_REPO);
                             # use a throwaway repo you own for live tests
CONFIDENCE_THRESHOLD=0.7     # min model confidence before auto-acting
WEBHOOK_ALLOW_UNSIGNED=false # dev-only: accept unsigned webhooks when no secret is set

# ----- GitHub ----------------------------------------------------------------
GITHUB_TOKEN=                # personal-access / app token (leave blank locally)
TARGET_REPO=<TARGET_REPO>    # "owner/name" of the repo to triage
GITHUB_WEBHOOK_SECRET=       # shared secret used to verify webhook signatures

# ----- LLM (Gemini via OpenAI-compatible endpoint) ---------------------------
GEMINI_API_KEY=              # Google AI Studio key (https://aistudio.google.com/apikey)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash   # fast/cheap reasoning model (swap provider via base_url/model)
OPENAI_API_KEY=              # only used by the OpenAI embedding backend (optional)
AUTOFIX_SEVERITIES=low       # severities the agent may attempt to auto-fix (comma-sep)

# ----- RAG / embeddings ------------------------------------------------------
EMBEDDING_BACKEND=sentence-transformers                  # "sentence-transformers" | "openai"
EMBEDDING_MODEL_ST=sentence-transformers/all-MiniLM-L6-v2  # local ST model (dim 384)
EMBEDDING_MODEL_OPENAI=text-embedding-3-small            # OpenAI embedding model (dim 1536)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=issues
EMBEDDING_CACHE_DIR=.cache/embeddings                    # on-disk sha256->vector cache
RETRIEVAL_SIMILARITY_THRESHOLD=0.5                       # min cosine in "duplicate" mode

# ----- Infra -----------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ----- Sandbox ---------------------------------------------------------------
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT_SECONDS=300
SANDBOX_MEM_LIMIT=512m
SANDBOX_CPU_QUOTA=1.0
