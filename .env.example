# =============================================================================
# Triage Agent — example environment. Copy to .env and fill in real values:
#     cp .env.example .env
# Nothing reads os.environ directly; shared/config.py is the single source.
# =============================================================================

# ----- Safety (read these first) ---------------------------------------------
DRY_RUN=true                 # true = never perform live GitHub writes
ENABLE_LIVE_WRITES=false     # master switch; must be true to ever write to GitHub
CONFIDENCE_THRESHOLD=0.7     # min model confidence before auto-acting

# ----- GitHub ----------------------------------------------------------------
GITHUB_TOKEN=                # personal-access / app token (leave blank locally)
TARGET_REPO=<TARGET_REPO>    # "owner/name" of the repo to triage
GITHUB_WEBHOOK_SECRET=       # shared secret used to verify webhook signatures

# ----- LLM -------------------------------------------------------------------
OPENAI_API_KEY=              # LLM provider API key
LLM_MODEL=gpt-4o-mini        # default chat/completion model

# ----- RAG / embeddings ------------------------------------------------------
EMBEDDING_BACKEND=sentence-transformers       # "sentence-transformers" | "openai"
EMBEDDING_MODEL_ST=BAAI/bge-small-en-v1.5     # local sentence-transformers model
EMBEDDING_MODEL_OPENAI=text-embedding-3-small # OpenAI embedding model
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=issues

# ----- Infra -----------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ----- Sandbox ---------------------------------------------------------------
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT_SECONDS=300
SANDBOX_MEM_LIMIT=512m
SANDBOX_CPU_QUOTA=1.0
